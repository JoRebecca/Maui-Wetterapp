<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.MainPage">

    <ScrollView>
        <VerticalStackLayout Padding="30,0" Spacing="25">

            <Entry Placeholder="Stadt eingeben..."
                   x:Name="CityEntry"
                   ReturnType="Search"
                  Completed="EnterEntry"/>

            <Button Text="Suchen"
                    Clicked="OnSearchClicked"
                    BackgroundColor="#ac99ea"
                    TextColor="White"
                    CornerRadius="10"/>

            <BoxView HeightRequest="1"
                     BackgroundColor="LightGray"/>

            <Label x:Name="CityLabel"
                   Text="Leipzig"
                   FontSize="32"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"/>

            <Image x:Name="WeatherIcon"
                   WidthRequest="80"
                   HeightRequest="80"
                   HorizontalOptions="Center"/>

            <VerticalStackLayout Padding="16" Spacing="12">

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                    <Border Grid.Column="0"
                            BackgroundColor="#ac99ea"
                            StrokeShape="RoundRectangle 15"
                            Padding="16">
                        <VerticalStackLayout VerticalOptions="Center">
                            <Label Text="Temperatur"
                                   TextColor="White"
                                   FontSize="13"
                                   Opacity="0.8"/>
                            <Label x:Name="TempLabel"
                                   Text="--°C"
                                   TextColor="White"
                                   FontSize="39"
                                   FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1"
                            BackgroundColor="#ac99ea"
                            StrokeShape="RoundRectangle 15"
                            Padding="16">
                        <VerticalStackLayout VerticalOptions="Center" Spacing="8">
                            <Label Text="Höchstwert"
                                   TextColor="White"
                                   FontSize="13"
                                   Opacity="0.8"/>
                            <Label x:Name="TempMaxLabel"
                                   Text="▲ --°C"
                                   TextColor="White"
                                   FontSize="22"
                                   FontAttributes="Bold"/>
                            <BoxView HeightRequest="1"
                                     BackgroundColor="White"
                                     Opacity="0.3"/>
                            <Label Text="Tiefstwert"
                                   TextColor="White"
                                   FontSize="13"
                                   Opacity="0.8"/>
                            <Label x:Name="TempMinLabel"
                                   Text="▼ --°C"
                                   TextColor="White"
                                   FontSize="22"
                                   FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </Border>

                </Grid>

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">

                    <Border Grid.Column="0"
                            BackgroundColor="#ac99ea"
                            StrokeShape="RoundRectangle 15"
                            Padding="16">
                        <VerticalStackLayout VerticalOptions="Center">

                            <Label x:Name="FeelsLikeLabel"
                                   Text="--°C"
                                   TextColor="White"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"/>
                            <Label Text="Gefühlte Temp."
                                   TextColor="White"
                                   FontSize="12"
                                   Opacity="0.8"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1"
                            BackgroundColor="#ac99ea"
                            StrokeShape="RoundRectangle 15"
                            Padding="16">
                        <VerticalStackLayout VerticalOptions="Center">

                            <Label x:Name="HumidityLabel"
                                   Text="--%"
                                   TextColor="White"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"/>
                            <Label Text="Feuchte"
                                   TextColor="White"
                                   FontSize="12"
                                   Opacity="0.8"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="2"
                            BackgroundColor="#ac99ea"
                            StrokeShape="RoundRectangle 15"
                            Padding="16">
                        <VerticalStackLayout VerticalOptions="Center">

                            <Label x:Name="WindLabel"
                                   Text="-- km/h"
                                   TextColor="White"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"/>
                            <Label Text="Wind"
                                   TextColor="White"
                                   FontSize="12"
                                   Opacity="0.8"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>

                </Grid>

                <Border BackgroundColor="#ac99ea"
                        StrokeShape="RoundRectangle 15"
                        Padding="16">
                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="Temperatur in Fahrenheit"
                               TextColor="White"
                               FontSize="13"
                               Opacity="0.8"
                               HorizontalOptions="Center"/>
                        <Label x:Name="FahrenheitLabel"
                               Text="--°F"
                               TextColor="White"
                               FontSize="32"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>